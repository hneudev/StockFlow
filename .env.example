# ─── Base de datos ────────────────────────────────────────────────────────────
# Cadena de conexión a MongoDB Atlas
# Obtener desde: Atlas Dashboard → Connect → Drivers → Node.js → Connection String
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/stockflow?retryWrites=true&w=majority

# ─── Worker ───────────────────────────────────────────────────────────────────
# Secret para proteger el endpoint POST /api/worker/process
# Solo Vercel Cron y el trigger interno tienen acceso a este valor
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WORKER_SECRET=reemplazar_con_secret_generado

# ─── App ──────────────────────────────────────────────────────────────────────
# URL base de la aplicación — usada para llamadas internas en server components
# Local:      http://localhost:3000
# Producción: stockflow-hneudev.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
